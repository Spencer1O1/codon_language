families:
  gene_format:
    version: 1.0.0
    description: shape of a gene file
    type: |
      { 
        gene: string, 
        description: Optional<string>, 
        imports: Optional<List<string>>, 
        codons: Map<string, TypeExprOrValue>, 
        traits: Optional<List<gene_trait_name>> 
      }

  gene_doc:
    version: 1.0.0
    description: documentation and validation rules for genes
    type: |
      {
        semantics: Optional<List<string>>,
        validation_rules: List<{
          code: string,
          severity: Union<"error", "warn", "info">,
          message: string,
        }>,
        examples: Optional<List<object>>,
      }

  language_doc:
    version: 1.0.0
    description: documentation and validation rules for core families
    type: |
      Map<string, {
        semantics: Optional<List<string>>,
        validation_rules: List<{
          code: string,
          severity: Union<"error", "warn", "info">,
          message: string,
        }>,
        examples: Optional<List<object>>,
      }>

  genome_format:
    version: 1.0.0
    description: shape of a genome (manifest) file
    type: |
      {
        schema_version: TypeExpr,
        project: TypeExpr,
        traits: TypeExpr
      }

  genome_doc:
    version: 1.0.0
    description: documentation and validation rules for root genome (manifest)
    type: |
      {
        semantics: Optional<List<string>>,
        validation_rules: List<{
          code: string,
          severity: Union<"error", "warn", "info">,
          message: string,
        }>,
        examples: Optional<List<object>>,
      }

  genome_layout:
    version: 1.0.0
    description: expected filesystem layout for a genome
    type: |
      {
        semantics: Optional<List<string>>,
        validation_rules: List<{
          code: string,
          severity: Union<"error", "warn", "info">,
          message: string,
        }>,
        examples: Optional<List<object>>,
      }
